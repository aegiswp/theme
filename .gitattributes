# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for code files
*.php text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.pdf binary

# Export ignore (files not included in distribution)
/.github export-ignore
/.kiro export-ignore
/.claude export-ignore
/tests export-ignore
/docs export-ignore
.gitattributes export-ignore
.gitignore export-ignore
.editorconfig export-ignore
phpcs.xml export-ignore
phpunit.xml export-ignore
Makefile export-ignore
PROJECT_SETUP.md export-ignore
CONTRIBUTING.md export-ignore
CONTRIBUTORS.md export-ignore
CODE_OF_CONDUCT.md export-ignore
