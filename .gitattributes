# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for code files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.php text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.sql text eol=lf
*.po text eol=lf
*.pot text eol=lf
*.mo binary

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.avif binary
*.tiff binary
*.bmp binary

# Font files
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Audio/Video files
*.mp4 binary
*.webm binary
*.ogg binary
*.mp3 binary
*.wav binary
*.flac binary
*.aac binary

# Archive files
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.rar binary
*.7z binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# Large generated files
*.map binary
*.asset.php text eol=lf
