{
  "name": "aegis-theme",
  "version": "1.0.0",
  "description": "Aegis - Native Block Framework",
  "author": "Atmostfear Entertainment",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "WordPress",
    "Framework",
    "Block Theme"
  ],
  "homepage": "https://github.com/aegiswp/theme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aegiswp/theme.git"
  },
  "bugs": {
    "url": "https://github.com/aegiswp/theme/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@wordpress/element": "^6.46.0",
    "@wordpress/env": "^11.0.0",
    "@wordpress/scripts": "^32.0.0",
    "pa11y-ci": "^3.1.0"
  },
  "overrides": {
    "axios": ">=1.15.0",
    "qs": ">=6.14.1",
    "glob": ">=10.5.0",
    "webpack-dev-server": ">=5.2.2",
    "lodash": ">=4.17.21",
    "lodash-es": ">=4.17.21",
    "fast-xml-parser": ">=5.7.2",
    "basic-ftp": ">=5.3.0",
    "minimatch": ">=9.0.0",
    "serialize-javascript": ">=7.0.5",
    "immutable": ">=5.1.5",
    "svgo": ">=3.3.3",
    "postcss": ">=8.5.10",
    "uuid": ">=11.0.0"
  },
  "scripts": {
    "build": "wp-scripts build --webpack-copy-php --blocks-manifest && php tools/generate-blocks-manifest.php",
    "build:dev": "wp-scripts build --mode=development --webpack-copy-php --blocks-manifest && php tools/generate-blocks-manifest.php",
    "dev": "wp-scripts start --webpack-copy-php --blocks-manifest",
    "start": "wp-scripts start --webpack-copy-php --blocks-manifest",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:restart": "wp-env stop && wp-env start",
    "env:clean": "wp-env clean all",
    "env:install": "wp-env run cli -- bash -c \"wp core install --url=http://localhost:8888 --title=Aegis-Dev --admin_user=admin --admin_password=password --admin_email=dev@local.invalid --skip-email || true; wp theme activate aegis\"",
    "env:cli": "wp-env run cli -- wp",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:pkg-json",
    "lint:js": "wp-scripts lint-js",
    "lint:css": "wp-scripts lint-style",
    "lint:pkg-json": "wp-scripts lint-pkg-json",
    "format": "wp-scripts format",
    "test:php": "composer test:php",
    "clean": "node tools/clean-build.js",
    "audit-patterns": "wp eval-file tools/audit-patterns.php",
    "audit-patterns:studio": "studio wp eval-file tools/audit-patterns.php",
    "translate": "node tools/prepare-translate.js && wp i18n make-pot . languages/aegis.pot --domain=aegis --skip-block-json --skip-theme-json --exclude=node_modules,vendor,.git,dist,.wp-env && node tools/finish-translate.js",
    "translate:studio": "node tools/prepare-translate.js && studio wp --path ../../.. i18n make-pot wp-content/themes/aegis wp-content/themes/aegis/languages/aegis.pot --domain=aegis --skip-block-json --skip-theme-json --exclude=node_modules,vendor,.git,dist,.wp-env && node tools/finish-translate.js"
  }
}
