# === WordPress Theme Ignore ===

# Node.js dependencies and build artifacts
node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# Block build artifacts (generated by webpack, keep source files)
# These are regenerated on npm run build
src/Blocks/*/*.js
src/Blocks/*/*.js.map
src/Blocks/*/*.css
src/Blocks/*/*.css.map
src/Blocks/*/*.asset.php
src/Blocks/*/*-rtl.css
!src/Blocks/*/index.tsx
!src/Blocks/*/edit.tsx
!src/Blocks/*/save.tsx
!src/Blocks/*/view.ts
!src/Blocks/*/*.scss
!src/Blocks/*/block.json
!src/Blocks/*/render.php

# Editor build artifacts (generated by webpack)
src/Blocks/editor/*.js
src/Blocks/editor/*.js.map
src/Blocks/editor/*.css
src/Blocks/editor/*.css.map
src/Blocks/editor/*.asset.php
src/Blocks/editor/*-rtl.css

# Admin build artifacts (generated by webpack)
src/Admin/build/

# Modal block patterns (development only, not for distribution - RC 3)
/patterns/modal/modal-video.php
/patterns/modal/modal-newsletter.php
/patterns/modal/modal-contact.php
/patterns/modal/modal-cookie-consent.php

# Composer dependencies
# Note: composer.lock is tracked for reproducible builds

# WordPress uploads and cache (if present)
wp-content/uploads/
wp-content/cache/

# Database and sensitive files
*.sql
*.sqlite
*.db

# Environment files
.env
.env.local
.env.*.local
.env.production
.env.staging

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Source maps (keep for debugging, remove if you don't want them)
# *.map

# IDE/project files
.vscode/
.idea/
.windsurf/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Docker
.dockerignore
/db_data/
/wp_uploads/
docker-compose.override.yml

# Testing
coverage/
.nyc_output/
*.lcov

# Cache directories
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Temporary files
*.bak
*.tmp
*.temp
*.orig

# Local development
local-*.json
*.local.js
*.local.ts

# Secrets and credentials (never commit these)
*.pem
*.key
*.crt
*.p12
secrets.json
credentials.json

# WordPress specific
debug.log
error_log
php_errorlog

# Backup files
*~
*.backup

# === End of WordPress Theme Ignore ===
