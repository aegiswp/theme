# Dependencies
node_modules/
vendor/

# IDE
.vscode/
.idea/
.claude/
.fleet/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Dot-prefixed folders/files in patterns (e.g. .template/)
patterns/.*

# Ephemeral / scratch (e.g. *.pretty.tmp from local formatting)
*.tmp
*.temp
*.bak
*.backup

# Dev tooling (standalone packages, not part of theme runtime)
# Track tools/wpaudit so CI can run its PHPUnit suite (aegis/wpaudit path repo).
tools/*
!tools/wpaudit/
!tools/wpaudit/**

# Audit tool legacy paths (moved to tools/wpaudit)
config/
src/Analyzers/
src/Models/
src/Enums/
src/Interfaces/
src/ConfigurationManager.php
src/DesignSystem/

# Test coverage
.phpunit.result.cache
.phpunit.cache/
coverage/
*.coverage
phpunit-report.xml

# E2E / browser testing (if added under the theme)
playwright-report/
test-results/

# Build artifacts — src/Blocks/ (webpack output)
src/Blocks/*/index.js
src/Blocks/*/view.js
src/Blocks/*/style.js
src/Blocks/*/index.css
src/Blocks/*/style.css
src/Blocks/*/style-style.css
src/Blocks/*/*.asset.php
src/Blocks/*/*.js.map
src/Blocks/*/*.css.map
src/Blocks/*/*-rtl.css

# Build artifacts — src/Blocks/editor/ (webpack output)
src/Blocks/editor/

# Build artifacts — src/Admin/build/ (webpack output)
src/Admin/build/

# Build artifacts — general
/build/
/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*.local

# wp-env (local-only overrides; base config is .wp-env.json in repo)
.wp-env.override.json

# Composer HTTP basic auth (private packages) — never commit
auth.json

# Local dev stacks (keep machine-specific config out of git)
.ddev/
.vagrant/

# Cache
.cache/
.eslintcache
.stylelintcache
.pnpm-store/
