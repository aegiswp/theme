# Dependencies
node_modules/
# Ignore Composer-managed packages, but keep the vendored first-party Aegis
# framework packages tracked: they are path-repository sources required for
# `composer install` to resolve aegis/framework and aegis/icons on a fresh
# clone (see "repositories" in composer.json).
# Per-package composer.json and LICENSE stay in Git; README is optional dev docs.
# .distignore strips nested composer.json/README/etc. from the release zip.
vendor/*
!vendor/aegis/
!vendor/aegis/**

# IDE
.vscode/
.idea/
.claude/
.fleet/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Dot-prefixed folders/files in patterns (e.g. .template/)
patterns/.*

# Ephemeral / scratch (e.g. *.pretty.tmp from local formatting)
*.tmp
*.temp
*.bak
*.backup

# Dev tooling (not part of theme runtime; release zip excludes tools/ via .distignore)
tools/scratch/
tools/wpaudit/vendor/
tools/wpaudit/.phpunit.cache/

# One-off dev/migration scripts (not part of theme runtime)
bin/
scripts/

# Audit tool legacy paths (moved to tools/wpaudit)
config/
src/Analyzers/
src/Models/
src/Enums/
src/Interfaces/
src/ConfigurationManager.php
src/DesignSystem/

# Test coverage
.phpunit.result.cache
.phpunit.cache/
coverage/
*.coverage
phpunit-report.xml

# E2E / browser testing (if added under the theme)
playwright-report/
test-results/

# Build artifacts — src/Blocks/ (webpack output)
src/Blocks/*/index.js
src/Blocks/*/view.js
src/Blocks/*/style.js
src/Blocks/*/index.css
src/Blocks/*/style.css
src/Blocks/*/style-style.css
src/Blocks/*/*.asset.php
src/Blocks/*/*.js.map
src/Blocks/*/*.css.map
src/Blocks/*/*-rtl.css

# Build artifacts — src/Blocks/editor/ (webpack output)
src/Blocks/editor/

# Build artifacts — src/Admin/build/ (webpack output)
src/Admin/build/

# Build artifacts — general
/build/
/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*.local

# wp-env (local-only overrides; base config is .wp-env.json in repo)
.wp-env.override.json

# Composer HTTP basic auth (private packages) — never commit
auth.json

# Local dev stacks (keep machine-specific config out of git)
.ddev/
.vagrant/

# Cache
.cache/
.eslintcache
.stylelintcache
.pnpm-store/
/.kiro
AGENTS.md
DESIGN.md
/tests
docs/_footer.md
docs/_sidebar.md
