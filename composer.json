{
    "name": "aegiswp/theme",
    "description": "Aegis — Native Block Framework for WordPress",
    "type": "wordpress-theme",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Atmostfear Entertainment",
            "homepage": "https://www.atmostfear-entertainment.com/"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "Aegis\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
