{
    "name": "aegiswp/theme",
    "description": "Aegis — Native Block Framework for WordPress",
    "type": "wordpress-theme",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Atmostfear Entertainment",
            "homepage": "https://www.atmostfear-entertainment.com/"
        }
    ],
    "require": {
        "php": ">=7.4",
        "aegis/framework": "dev-main",
        "aegis/container": "dev-main",
        "aegis/dom": "dev-main",
        "aegis/hooks": "dev-main",
        "aegis/icons": "dev-main",
        "aegis/utilities": "dev-main",
        "enshrined/svg-sanitize": "dev-master",
        "psr/container": "^2.0@dev"
    },
    "require-dev": {
        "aegis/wpaudit": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "tools/wpaudit"
        }
    ],
    "autoload": {
        "psr-4": {
            "Aegis\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
